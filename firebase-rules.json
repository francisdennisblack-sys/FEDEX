{
  "rules": {
    "posts": {
      "$postId": {
        ".read": true,
        // Allow authenticated clients to create/update posts. Public reads are allowed above.
        ".write": "auth != null",
        // Basic validation to avoid rejecting posts that include boost metadata
        "boostRequested": {
          ".validate": "newData.isBoolean()"
        },
        "boostIntent": {
          ".validate": "newData.val() === null || newData.hasChildren()"
        },
        "boostPaidAt": {
          ".validate": "newData.isNumber() || newData.val() === null"
        }
      }
    },
    "users": {
      "$userId": {
        "posts": {
          "$postId": {
            ".read": true,
            ".write": true
          }
        },
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "networks": {
      "$networkId": {
        "posts": {
          "$postId": {
            ".read": "auth != null",
            ".write": "auth != null"
          }
        }
      }
    },
    "user-posts": {
      "$userId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "user-votes": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "onlineUsers": {
      ".read": true,
      ".write": true,
      "$userId": {
        ".read": true,
        ".write": true
      }
    },
    "poi_registry": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "globalData": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "activity": {
      "$userId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    }
  }
}
