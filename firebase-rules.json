{
  "rules": {
    "posts": {
      "$postId": {
        ".read": true,
        ".write": true
      }
    },
    "users": {
      "$userId": {
        "posts": {
          "$postId": {
            ".read": true,
            ".write": true
          }
        },
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "networks": {
      "$networkId": {
        "posts": {
          "$postId": {
            ".read": "auth != null",
            ".write": "auth != null"
          }
        }
      }
    },
    "user-posts": {
      "$userId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "user-votes": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "onlineUsers": {
      ".read": "auth != null",
      "$userId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },
    "poi_registry": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "globalData": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "activity": {
      "$userId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    }
  }
}
