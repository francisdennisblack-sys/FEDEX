{
  // Keep editor stable in this heavy workspace (1.3GB with large JSON data files)
  "files.watcherExclude": {
    "**/.git/**": true,
    "**/node_modules/**": true,
    "**/.vercel/**": true,
    "data/**": true,
    "pois/**": true,
    "assets/**": true,
    "**/*.log": true
  },
  "search.exclude": {
    "**/.git": true,
    "**/node_modules": true,
    "**/.vercel": true,
    "data/**": true,
    "pois/**": true,
    "assets/**": true,
    "**/*.log": true
  },
  "files.exclude": {
    "**/.git": true,
    "**/.vercel": true,
    "data/**": true,
    "pois/**": true,
    "assets/**": true,
    "**/*.log": true
  },
  "javascript.validate.enable": false,
  "typescript.disableAutomaticTypeAcquisition": true,
  "html.validate.scripts": false,
  "files.maxMemoryForLargeFilesMB": 4096
}
